#!/usr/bin/env python3
"""
Deprecated launcher for the legacy ``hermes`` command name.

Prefer ``./linket`` (or the installed ``linket`` entry point). This
shim emits a one-time deprecation warning and dispatches to the same
``hermes_cli.main:main`` entry, so existing scripts and shell aliases
keep working through the rename. Set
``LINKET_SUPPRESS_LEGACY_WARNING=1`` to silence the warning.
"""

if __name__ == "__main__":
    from hermes_cli._legacy_alias import warn_deprecated
    warn_deprecated("hermes", "linket")
    from hermes_cli.main import main
    main()
